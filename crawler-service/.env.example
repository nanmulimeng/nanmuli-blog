# Web Collector - Python Crawler Service 环境配置

# ===== 基础服务配置（两种模式共享）=====
HOST=0.0.0.0
PORT=8500
DEBUG=false
LOG_LEVEL=INFO

# ===== 爬取限制（两种模式共享）=====
MAX_PAGES_DEFAULT=10
MAX_PAGES_LIMIT=20
MAX_DEPTH_LIMIT=3
REQUEST_TIMEOUT=60

# ===== 模式切换 =====
# true = 独立部署模式（带任务管理+SQLite+认证）
# false 或不设置 = 纯 API 模式（作为博客微服务）
STANDALONE=false

# ===== 独立模式专用（STANDALONE=true 时生效）=====

# SQLite 数据库路径
DB_PATH=data/crawler.db

# API Key 认证（逗号分隔，支持多个 key）
API_KEYS=sk-your-secret-key-here

# 是否启用认证（开发环境可设为 false）
AUTH_ENABLED=true

# 最大并发爬取任务数
MAX_CONCURRENT_TASKS=3

# Markdown 导出目录
EXPORT_DIR=exports
