# Web Collector - Python Crawler Service 环境配置

# ===== 基础服务配置（两种模式共享）=====
HOST=0.0.0.0
PORT=8500
DEBUG=false
LOG_LEVEL=INFO

# ===== 爬取限制（两种模式共享）=====
MAX_PAGES_LIMIT=20
MAX_DEPTH_LIMIT=3
MAX_CONCURRENT_CRAWLS=3

# ===== 模式切换 =====
# true = 独立部署模式（带任务管理+AI整理+SQLite+认证）
# false 或不设置 = 纯 API 模式（作为微服务被其他系统调用）
STANDALONE=false

# ===== 独立模式专用（STANDALONE=true 时生效）=====

# SQLite 数据库路径
DB_PATH=data/crawler.db

# API Key 认证（逗号分隔，支持多个 key）
API_KEYS=sk-your-secret-key-here

# 是否启用认证（开发环境可设为 false）
AUTH_ENABLED=true

# 最大并发爬取任务数
MAX_CONCURRENT_TASKS=3

# ===== 代理与反爬配置 =====
# HTTP/HTTPS/SOCKS5 代理（中国大陆IP建议配置，格式：protocol://user:pass@host:port）
# PROXY_URL=http://127.0.0.1:7890
# PROXY_URL=socks5://127.0.0.1:1080

# 同域名去重上限（每个域名最多保留 N 个搜索结果，默认 2）
MAX_DOMAIN_DEDUP=2

# ===== 搜索模块超时与策略配置 =====
# 搜索结果页默认超时（毫秒）
SEARCH_PAGE_TIMEOUT_MS=15000
# 浏览器抓取超时（毫秒）
SEARCH_BROWSER_FETCH_TIMEOUT_MS=20000
# httpx 降级超时（秒）
SEARCH_HTTPX_FALLBACK_TIMEOUT=15
# 共享搜索客户端超时（秒）
SEARCH_CLIENT_TIMEOUT=30
# 搜狗预热超时（秒）
SEARCH_WARMUP_TIMEOUT=10
# 搜索页获取重试次数
SEARCH_PAGE_RETRIES=2
# 每个搜索引擎最大翻页数
SEARCH_MAX_PAGES_PER_ENGINE=5
# 搜索结果最小词数（低于此值视为低质量）
SEARCH_MIN_WORD_COUNT=50

# ===== 搜索引擎延迟配置（秒）=====
# 引擎切换间隔
SEARCH_ENGINE_SWITCH_DELAY_MIN=2.0
SEARCH_ENGINE_SWITCH_DELAY_MAX=5.0
# 翻页间隔
SEARCH_PAGE_DELAY_MIN=0.8
SEARCH_PAGE_DELAY_MAX=2.0
# 优化轮间隔
OPTIMIZATION_ROUND_DELAY_MIN=2.0
OPTIMIZATION_ROUND_DELAY_MAX=4.0

# ===== 质量评估配置 =====
# 综合评分中来源可信度权重
QUALITY_SOURCE_WEIGHT=0.4
# 综合评分中内容质量权重
QUALITY_CONTENT_WEIGHT=0.6
# 内容质量推荐：保留阈值（总分>=此值且无付费墙 → keep）
QUALITY_KEEP_THRESHOLD=70
# 内容质量推荐：审查阈值（总分>=此值 → review）
QUALITY_REVIEW_THRESHOLD=50
# 综合评分：通过阈值
EVAL_PASS_THRESHOLD=65
# 综合评分：审查阈值
EVAL_REVIEW_THRESHOLD=45

# ===== 评估维度权重（总和应为 1.0）=====
EVAL_WEIGHT_ANGLE=0.25
EVAL_WEIGHT_SOURCE=0.20
EVAL_WEIGHT_DEPTH=0.15
EVAL_WEIGHT_TEMPORAL=0.15
EVAL_WEIGHT_PERSPECTIVE=0.15
EVAL_WEIGHT_LANGUAGE=0.10

# ===== 独立模式认证配置 =====
# 需要认证的路径前缀（逗号分隔）
AUTH_PROTECTED_PREFIXES=/api/v1,/crawl,/organize,/keyword
# API Key 认证头名称
AUTH_HEADER_NAME=X-API-Key

# ===== SQLite 配置 =====
# SQLite busy_timeout（毫秒）
DB_BUSY_TIMEOUT=5000

# ===== AI 内容整理配置 =====
# 启用后，爬取完成自动调用 AI 整理（单页摘要、多页综合、关键词优化等）
AI_ENABLED=false

# OpenAI 兼容 API 配置（支持 DashScope/DeepSeek/OpenAI 等）
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=sk-your-api-key-here
AI_MODEL=qwen-plus
AI_TEMPERATURE=0.3

# AI 超时（秒）
AI_CONNECT_TIMEOUT=10
AI_READ_TIMEOUT=90

# AI 重试策略
AI_MAX_RETRIES=2
AI_RATE_LIMIT_BACKOFF_MS=10000

# AI 内容预算（字符数）
AI_SINGLE_PAGE_MAX_CHARS=80000
AI_MULTI_PAGE_PER_MAX_CHARS=20000
AI_MULTI_PAGE_TOTAL_BUDGET=150000
# AI 调用最大输出 tokens
AI_MAX_TOKENS=8000
# 摘要最小长度（字符数）
AI_MIN_SUMMARY_LENGTH=10
# 全文最小长度（字符数）
AI_MIN_FULL_CONTENT_LENGTH=20
# 最大要点数
AI_MAX_KEY_POINTS=10
# 最大标签数
AI_MAX_TAGS=10

# ===== 日报配置 =====
# 启用定时日报生成（需 AI_ENABLED=true）
DIGEST_ENABLED=false

# 定时 cron 表达式（默认：工作日 8:00）
DIGEST_CRON=0 8 * * 1-5

# 日报板块配置（JSON 数组，每个板块含 name/keyword/time_range/max_items）
# DIGEST_SECTIONS=[{"name":"news","keyword":"tech news","time_range":"day","max_items":5},{"name":"articles","keyword":"technology blog","time_range":"week","max_items":3},{"name":"opensource","keyword":"GitHub trending","time_range":"week","max_items":3}]

# 日报专用搜索引擎（默认 bing）
DIGEST_SEARCH_ENGINE=bing

# ===== 回调配置（任务完成后通知 Java 后端）=====
# Java 后端的回调端点（为空则不回调）
# CALLBACK_URL=http://localhost:8080/api/internal/collector/callback
# 与 Java 端 crawler.callback.api-key 一致的共享密钥
# CALLBACK_API_KEY=your-shared-secret

# Java 后端地址（用于拉取订阅源配置生成日报板块）
# JAVA_API_URL=http://localhost:8080

# ===== 质量评估关键词（逗号分隔，可覆盖默认值）=====
# QUALITY_CLICKBAIT_KEYWORDS=震惊,绝了,逆天,...
# QUALITY_AD_KEYWORDS=限时优惠,点击购买,...
# QUALITY_PAYWALL_INDICATORS=subscribe to read,...

# ===== 自动优化引擎配置 =====
# 启用后，关键词搜索和日报生成会自动进行覆盖度评估和补充搜索
OPTIMIZATION_ENABLED=false

# 目标覆盖度分数（0-1，达到此分数后停止优化循环）
OPTIMIZATION_TARGET_SCORE=0.7

# 最大优化轮次（每轮会触发一次额外的搜索+评估）
OPTIMIZATION_MAX_ROUNDS=3

# 最小改善阈值（相邻两轮分数差低于此值时提前终止）
OPTIMIZATION_MIN_IMPROVEMENT=0.03

# 应用场景：keyword（仅关键词任务）/ digest（仅日报）/ both（两者都优化）
OPTIMIZATION_MODE=keyword

# ===== 信息茧房突破配置 =====
# 启用后，当搜索结果来源单一或语言单一时，自动补充跨语言搜索
BUBBLE_BREAKER_ENABLED=false

# Shannon 熵低于此值时触发来源补充（0-1）
BUBBLE_MIN_SOURCE_DIVERSITY=0.6

# 是否启用跨语言扩展（中文→英文翻译补充搜索）
BUBBLE_CROSS_LANGUAGE=true
