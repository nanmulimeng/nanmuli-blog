# ============================================
# Nanmuli Blog 部署环境配置
# ============================================

# 数据库密码（生产环境必须修改）
DB_PASSWORD=nanmuli_blog_2024

# JWT/Sa-Token 密钥（生产环境必须修改）
SA_TOKEN_SECRET=nanmuli_secret_key_for_sa_token_2024

# AI 配置
AI_ENABLED=true
DASH_SCOPE_API_KEY=
# 日报配置
DIGEST_ENABLED=true
# 代理配置
PROXY_URL=http://127.0.0.1:7890
# Mihomo 代理订阅 URL（部署时运行 bash deploy/mihomo/install.sh 自动配置）
# SUBSCRIPTION_URL=https://sub.example.com/link/xxx
# 回调配置
JAVA_API_URL=http://host.docker.internal:8081

# 文件存储配置
STORAGE_TYPE=local
