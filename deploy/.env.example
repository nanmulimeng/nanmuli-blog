# ============================================
# Nanmuli Blog 部署环境配置
# ============================================

# 数据库密码（生产环境必须修改）
DB_PASSWORD=your_secure_password_here

# JWT/Sa-Token 密钥（生产环境必须修改）
SA_TOKEN_SECRET=your_random_secret_key_here

# AI 配置（可选）
AI_ENABLED=false
DASH_SCOPE_API_KEY=your_dash_scope_api_key

# 爬虫代理配置
# ============================================
# 开发环境：本地 Clash Verge 代理
# PROXY_URL=http://127.0.0.1:7890
#
# 服务器环境：运行 bash deploy/mihomo/install.sh 安装 Mihomo 代理
# 安装后 PROXY_URL=http://127.0.0.1:7890 即可
# 若有订阅链接，安装时输入；若无，安装后手动编辑 /etc/mihomo/config.yaml 添加节点
PROXY_URL=http://127.0.0.1:7890

# 文件存储配置
STORAGE_TYPE=local
# 如使用阿里云OSS，配置以下参数
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your_access_key
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET_NAME=your_bucket_name
